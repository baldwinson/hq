# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
#
# For local development with Docker Compose (run from project root):
#   docker compose up -d
# Then use:
DATABASE_URL=postgresql://baldwinson:baldwinson_dev@localhost:5433/baldwinson

# For production, use your hosted PostgreSQL URL:
# DATABASE_URL=postgresql://user:password@your-host:5432/your-database
