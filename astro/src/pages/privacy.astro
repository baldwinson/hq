---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { ExternalLink } from 'lucide-react';
---

<Layout 
	title="Privacy — Baldwinson"
	description="Privacy policy for Baldwinson. Information about data collection, use, and your rights."
>
	<section class="hero-section site-hero site-padding">
		<div class="site-hero-inner">
			<p class="mb-4 site-eyebrow">
				Legal
			</p>
			<h1 class="hero-primary text-[1.75rem] leading-[1.2] tracking-[-0.01em] text-foreground sm:text-[2.125rem] sm:leading-[1.15] lg:text-[2.75rem] lg:leading-[1.15]">
				Privacy Policy
			</h1>
			
			<p class="hero-secondary mt-[1em] text-[1rem] leading-[1.5] text-foreground/70 sm:text-[1.125rem] lg:text-[1.25rem]">
				How we handle your information.
			</p>
		</div>
	</section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Data we collect
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				This website collects minimal data. The only personal information we collect is:
			</p>
			<ul class="ml-4 list-disc space-y-2">
				<li><strong class="text-foreground">Email address</strong> — Collected only if you voluntarily join the Baldwinson Ethical Technologies waitlist.</li>
			</ul>
		</div>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			How we use your data
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				Email addresses submitted through the waitlist are used solely to notify you when the first Baldwinson Ethical Technologies publication is available.
			</p>
			<p>
				We do not sell, share, or transfer your email address to third parties. We do not send marketing emails, newsletters, or promotional content beyond the stated purpose.
			</p>
		</div>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Data retention
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				Waitlist email addresses are retained until the notification is sent, after which they are deleted unless you explicitly opt in to future communications.
			</p>
		</div>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Your rights
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				You may request deletion of your email address at any time by contacting us. We will remove your information promptly upon request.
			</p>
		</div>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Analytics
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				This website uses <a href="https://vercel.com/docs/analytics" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 underline underline-offset-2 hover:text-foreground/80">Vercel Analytics<ExternalLink className="h-3.5 w-3.5" aria-hidden="true" /></a> to understand how visitors interact with the site. Vercel Analytics is a privacy-focused service that does not use cookies or collect personally identifiable information.
			</p>
			<p>
				Data collected includes anonymized usage metrics such as page views and general geographic region. This information helps us improve the website and cannot be used to identify you.
			</p>
		</div>
	</Section>

	<Section>
		<p class="mb-6 site-eyebrow">
			Contact
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				For privacy-related inquiries or data deletion requests, contact us via the correspondence details on the <a href="/" class="underline underline-offset-2 hover:text-foreground/80">HQ page</a>.
			</p>
		</div>
		<p class="mt-8 text-xs text-foreground/40">
			Last updated: January 2026
		</p>
	</Section>
</Layout>
