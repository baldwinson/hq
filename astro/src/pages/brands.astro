---
import Layout from '../layouts/Layout.astro';
import EyebrowHeading from '../components/EyebrowHeading.astro';
import Section from '../components/Section.astro';
import { ExternalLink } from '@lucide/astro';

const brands = [
	{
		name: 'Arlington Shelves',
		description: 'Designs and supplies modular shelving systems for environments where spatial order must be specified rather than improvised, including academic, laboratory, and engineering settings. Operations include system configuration, direct-to-business supply, warehousing, and fulfillment.',
		url: 'https://arlingtonshelves.com',
	},
	{
		name: 'AshNote',
		description: 'A structured knowledge platform for notes, documents, and sensitive working material. Built with advanced encryption and controlled file expiration, Ashnote helps protect intellectual property by reducing unnecessary persistence of confidential information.',
		url: 'https://ashnote.app',
	},
];
---

<Layout 
	title="Brands — Baldwinson"
	description="Operating brands under Baldwinson. A registry of independent commercial entities and their operational scope."
>
	<EyebrowHeading 
		title="Brands"
		lead="Baldwinson operates a set of independent commercial brands. This page lists those operating entities and links to their standalone sites."
	/>

	<Section>
		<p class="mb-8 site-eyebrow">
			Operating entities
		</p>
		
		<div class="space-y-6">
			{brands.map((brand) => (
				<article class="border-b border-foreground/10 pb-6 last:border-b-0 last:pb-0">
					<h2 class="text-base font-medium text-foreground sm:text-lg">
						{brand.name}
					</h2>
					<p class="mt-2 text-sm leading-relaxed text-foreground/70 sm:text-base">
						{brand.description}
					</p>
					<a 
						href={brand.url}
						target="_blank"
						rel="noopener noreferrer"
						class="site-link mt-3 inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
					>
						{brand.url.replace(/^https?:\/\//, '')}
						<ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
					</a>
				</article>
			))}
		</div>
	</Section>
</Layout>
