---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Baldwinson | Ethics — Registry">
	<section class="hero-section site-hero site-padding">
		<div class="site-hero-inner">
			<p class="mb-4 text-xs font-medium uppercase tracking-[0.15em] text-muted-foreground/60">
				Ethics
			</p>
			<h1 class="hero-primary text-[1.75rem] leading-[1.2] tracking-[-0.01em] text-foreground sm:text-[2.125rem] sm:leading-[1.15] lg:text-[2.75rem] lg:leading-[1.15]">
				Registry
			</h1>
			
			<p class="hero-secondary mt-[1em] text-[1rem] leading-[1.5] text-foreground/70 sm:text-[1.125rem] lg:text-[1.25rem]">
				Self-attested organizational commitments.
			</p>
		</div>
	</section>

	<section class="site-section site-padding">
		<div class="site-container">
			<p class="text-sm text-muted-foreground/60 sm:text-base">
				Registry is not yet open for submissions.
			</p>
			<a 
				href="/ethics" 
				class="mt-8 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
				Back to Ethics
			</a>
		</div>
	</section>
</Layout>
