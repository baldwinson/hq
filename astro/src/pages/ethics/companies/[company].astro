---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/Section.astro';
import { ArrowLeft } from 'lucide-react';

export function getStaticPaths() {
	return [
		{ params: { company: 'placeholder' } }
	];
}

const { company } = Astro.params;
const companyName = company.charAt(0).toUpperCase() + company.slice(1).replace(/-/g, ' ');
---

<Layout 
	title={`${companyName} — Baldwinson Ethical Technologies`}
	description={`Independent ethical performance evaluation for ${companyName}. Assessment based on documented behavior, time-weighted accountability, and evidence over disclosure.`}
>
	<section class="hero-section site-hero site-padding">
		<div class="site-hero-inner">
			<p class="mb-4 site-eyebrow">
				Company Evaluation
			</p>
			<h1 class="hero-primary text-[1.75rem] leading-[1.2] tracking-[-0.01em] text-foreground sm:text-[2.125rem] sm:leading-[1.15] lg:text-[2.75rem] lg:leading-[1.15]">
				{companyName}
			</h1>
			
			<p class="hero-secondary mt-[1em] text-[1rem] leading-[1.5] text-foreground/70 sm:text-[1.125rem] lg:text-[1.25rem]">
				Ethical performance evaluation.
			</p>
		</div>
	</section>

	<Section>
		<p class="text-sm text-muted-foreground/60 sm:text-base">
			Company evaluations are in development.
		</p>
		<a 
			href="/ethics/evaluations" 
			class="site-link mt-8 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
		>
			<ArrowLeft className="h-4 w-4" aria-hidden="true" />
			Back to Evaluations
		</a>
	</Section>
</Layout>
