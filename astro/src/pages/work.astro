---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Baldwinson | Work">
	<section class="hero-section site-hero site-padding">
		<div class="site-hero-inner">
			<h1 class="hero-primary text-[1.75rem] leading-[1.2] tracking-[-0.01em] text-foreground sm:text-[2.125rem] sm:leading-[1.15] lg:text-[2.75rem] lg:leading-[1.15]">
				Work across software systems, organizational structure, and operational scale.
			</h1>
			
			<p class="hero-secondary mt-[1em] text-[1rem] leading-[1.5] text-foreground/70 sm:text-[1.125rem] lg:text-[1.25rem]">
				Engagements range from hands-on system design and implementation to executive-level structuring, decision frameworks, and long-term technical strategy.
			</p>
		</div>
	</section>

	<section class="site-section site-padding">
		<div class="site-container">
			<div class="space-y-16">
				<div>
					<h2 class="mb-4 text-base font-medium text-foreground sm:text-lg">
						Engineering
					</h2>
					<p class="text-sm leading-relaxed text-muted-foreground/70 sm:text-base">
						Software architecture, system design, and implementation across distributed systems, data infrastructure, and product engineering.
					</p>
				</div>
				
				<div>
					<h2 class="mb-4 text-base font-medium text-foreground sm:text-lg">
						Systems & Scale
					</h2>
					<p class="text-sm leading-relaxed text-muted-foreground/70 sm:text-base">
						Performance optimization, reliability engineering, and infrastructure design for high-throughput, mission-critical systems.
					</p>
				</div>
				
				<div>
					<h2 class="mb-4 text-base font-medium text-foreground sm:text-lg">
						Organizational Design
					</h2>
					<p class="text-sm leading-relaxed text-muted-foreground/70 sm:text-base">
						Team structure, technical leadership frameworks, and engineering culture development aligned with business objectives.
					</p>
				</div>
				
				<div>
					<h2 class="mb-4 text-base font-medium text-foreground sm:text-lg">
						Advisory
					</h2>
					<p class="text-sm leading-relaxed text-muted-foreground/70 sm:text-base">
						Strategic guidance on technical direction, vendor evaluation, build-vs-buy decisions, and due diligence for technology investments.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="site-section site-padding">
		<div class="site-container">
			<p class="mb-12 site-eyebrow">
				Background
			</p>
			<div class="flex flex-wrap gap-x-8 gap-y-4">
				<span class="text-sm text-foreground/70">Wayfair</span>
				<span class="text-sm text-foreground/70">Peloton</span>
				<span class="text-sm text-foreground/70">Clear Street</span>
				<span class="text-sm text-foreground/70">ReadyMode</span>
			</div>
		</div>
	</section>
</Layout>
