---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Baldwinson | Apps">
	<section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-4xl text-center">
			<h1 class="mb-6 text-3xl font-light tracking-tight text-foreground sm:text-4xl md:text-5xl">
				Apps
			</h1>
			
			<p class="mx-auto mb-12 max-w-2xl text-lg font-light leading-relaxed text-muted-foreground">
				External projects and applications.
			</p>

			<div class="mx-auto max-w-xl border-t border-border/40 pt-12">
				<p class="mb-8 text-xs font-medium uppercase tracking-widest text-muted-foreground">
					Projects
				</p>
				
				<div class="grid gap-4">
					<div class="rounded-lg border border-border/40 bg-card/50 p-6 text-left transition-colors hover:bg-card">
						<p class="text-sm text-muted-foreground/60">
							App listings coming soon.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
