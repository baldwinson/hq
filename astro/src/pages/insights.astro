---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Baldwinson | Insights">
	<section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-4xl text-center">
			<h1 class="mb-6 text-3xl font-light tracking-tight text-foreground sm:text-4xl md:text-5xl">
				Insights
			</h1>
			
			<p class="mx-auto mb-12 max-w-2xl text-lg font-light leading-relaxed text-muted-foreground">
				Technical essays. Policy-grade analysis. Position papers.
			</p>

			<div class="mx-auto max-w-xl border-t border-border/40 pt-12">
				<div class="grid gap-4 text-sm text-muted-foreground">
					<div class="flex items-center justify-center gap-2">
						<span class="h-1 w-1 rounded-full bg-foreground/40"></span>
						Technical deep-dives
					</div>
					<div class="flex items-center justify-center gap-2">
						<span class="h-1 w-1 rounded-full bg-foreground/40"></span>
						Industry analysis
					</div>
					<div class="flex items-center justify-center gap-2">
						<span class="h-1 w-1 rounded-full bg-foreground/40"></span>
						Professional perspectives
					</div>
				</div>
			</div>

			<div class="mx-auto mt-16 max-w-xl">
				<p class="text-sm text-muted-foreground/60">
					Essays and analysis coming soon.
				</p>
			</div>
		</div>
	</section>
</Layout>
