---
import Layout from '../layouts/Layout.astro';
import EyebrowHeading from '../components/EyebrowHeading.astro';
import Section from '../components/Section.astro';

interface Publication {
	title: string;
	date: string;
	readTime: string;
	excerpt: string;
	area: string;
	href?: string;
}

const publications: Publication[] = [];

const formatDate = (dateStr: string) => {
	const date = new Date(dateStr);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<Layout 
	title="Insights — Baldwinson"
	description="Long-form analysis on technology, institutions, and ethical consequence. Deliberate, infrequent publications written to be read slowly and referenced over time."
>
	<EyebrowHeading 
		title="Insights"
		lead="Long-form analysis on technology, institutions, and ethical consequence."
	/>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Orientation
		</p>
		<div class="space-y-4 text-sm leading-relaxed text-foreground/70 sm:text-base">
			<p>
				This section collects long-form analytical work examining technology systems, institutional design, and the consequences of decisions made at scale.
			</p>
			<p>
				Publications here are deliberate and infrequent. They are written to be read slowly and referenced over time.
			</p>
		</div>
	</Section>

	<Section divider>
		<p class="mb-8 site-eyebrow">
			Areas of analysis
		</p>
		<div class="space-y-8">
			<div>
				<h3 class="mb-2 text-base font-medium text-foreground sm:text-lg">
					Institutional ethics and accountability
				</h3>
				<p class="text-sm leading-relaxed text-foreground/70 sm:text-base">
					Examination of ethical frameworks, indexes, licenses, and governance systems — including critiques of where they fail in practice.
				</p>
			</div>
			
			<div>
				<h3 class="mb-2 text-base font-medium text-foreground sm:text-lg">
					Policy, regulation, and economic consequence
				</h3>
				<p class="text-sm leading-relaxed text-foreground/70 sm:text-base">
					Analysis of tariffs, government agencies, and regulatory structures, with attention to downstream effects on businesses and individuals.
				</p>
			</div>
			
			<div>
				<h3 class="mb-2 text-base font-medium text-foreground sm:text-lg">
					Engineering judgment at scale
				</h3>
				<p class="text-sm leading-relaxed text-foreground/70 sm:text-base">
					Writing on technical decisions, system design, and tradeoffs where correctness, usability, and trust materially affect outcomes.
				</p>
			</div>
		</div>
		<p class="mt-8 text-xs text-foreground/40">
			These areas serve as mental models, not filters or categories.
		</p>
	</Section>

	<Section divider>
		<p class="mb-8 site-eyebrow">
			Publications
		</p>
		{publications.length > 0 ? (
			<div class="space-y-0">
				{publications.map((pub, index) => (
					<article class={`group py-6 ${index !== 0 ? 'border-t border-foreground/10' : ''}`}>
						<a href={pub.href || '#'} class="block">
							<div class="mb-2 flex items-center gap-3 text-xs text-foreground/40">
								<time datetime={pub.date}>{formatDate(pub.date)}</time>
								<span class="h-0.5 w-0.5 rounded-full bg-foreground/30"></span>
								<span>{pub.readTime} read</span>
							</div>
							<h3 class="mb-2 text-base font-medium leading-snug text-foreground transition-colors group-hover:text-foreground/80 sm:text-lg">
								{pub.title}
							</h3>
							<p class="text-sm leading-relaxed text-foreground/60 sm:text-base">
								{pub.excerpt}
							</p>
						</a>
					</article>
				))}
			</div>
		) : (
			<p class="text-sm text-foreground/50 sm:text-base">
				Publications coming soon.
			</p>
		)}
	</Section>

	<Section>
		<p class="mb-6 site-eyebrow">
			On frequency
		</p>
		<p class="text-sm leading-relaxed text-foreground/70 sm:text-base">
			New publications appear when there is something worth saying. There is no schedule, no quota, and no obligation to maintain cadence. Quality and precision take precedence over presence.
		</p>
	</Section>
</Layout>
