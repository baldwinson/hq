---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Insights — Baldwinson"
	description="Technical essays, policy-grade analysis, and position papers on technology governance, institutional design, and ethical decision-making."
>
	<section class="hero-section site-hero site-padding">
		<div class="site-hero-inner">
			<h1 class="hero-primary mb-6 text-3xl font-light tracking-tight text-foreground sm:text-4xl md:text-5xl">
				Insights
			</h1>
			
			<p class="hero-secondary mx-auto mb-12 max-w-2xl text-lg font-light leading-relaxed text-muted-foreground">
				Technical essays. Policy-grade analysis. Position papers.
			</p>

			<div class="border-t border-border/40 pt-12">
				<div class="grid gap-4 text-sm text-muted-foreground">
					<div class="flex items-center justify-center gap-2">
						<span class="h-1 w-1 rounded-full bg-foreground/40"></span>
						Technical deep-dives
					</div>
					<div class="flex items-center justify-center gap-2">
						<span class="h-1 w-1 rounded-full bg-foreground/40"></span>
						Industry analysis
					</div>
					<div class="flex items-center justify-center gap-2">
						<span class="h-1 w-1 rounded-full bg-foreground/40"></span>
						Professional perspectives
					</div>
				</div>
			</div>

			<div class="mx-auto mt-16 max-w-xl">
				<p class="text-sm text-muted-foreground/60">
					Essays and analysis coming soon.
				</p>
			</div>
		</div>
	</section>
</Layout>
