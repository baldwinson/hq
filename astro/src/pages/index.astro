---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ObfuscatedEmail from '../components/ObfuscatedEmail.astro';
---

<Layout 
	title="Baldwinson — Technology, Ethics, and Governance"
	description="Building durable systems at the intersection of technology, ethics, and governance. Independent work across software engineering, institutional design, and applied ethics."
>
	<section class="hero-section site-hero site-padding">
		<div class="site-hero-inner">
			<h1 class="hero-primary text-[1.75rem] leading-[1.2] tracking-[-0.01em] text-foreground sm:text-[2.125rem] sm:leading-[1.15] lg:text-[2.75rem] lg:leading-[1.15]">
				Building durable systems at the intersection of technology, ethics, and governance.
			</h1>
			
			<p class="hero-secondary mt-[1em] text-[1rem] leading-[1.5] text-foreground/70 sm:text-[1.125rem] lg:text-[1.25rem]">
				Independent work across software engineering, institutional design, and applied ethics.
			</p>
		</div>
	</section>

	<Section divider>
		<p class="mb-8 site-eyebrow">
			Areas of work
		</p>
		
		<div class="space-y-6">
			<a href="/work" class="group block">
				<h3 class="mb-2 flex items-center gap-2 text-base font-medium text-foreground transition-colors group-hover:text-foreground/80 sm:text-lg">
					Work
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 transition-all group-hover:translate-x-0.5 group-hover:opacity-70"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</h3>
				<p class="text-sm text-foreground/70 sm:text-base">
					Software systems, organizational structure, and operational scale.
				</p>
			</a>
			
			<a href="/insights" class="group block">
				<h3 class="mb-2 flex items-center gap-2 text-base font-medium text-foreground transition-colors group-hover:text-foreground/80 sm:text-lg">
					Insights
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 transition-all group-hover:translate-x-0.5 group-hover:opacity-70"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</h3>
				<p class="text-sm text-foreground/70 sm:text-base">
					Analysis and position papers on technology governance.
				</p>
			</a>
			
			<a href="/ethics" class="group block">
				<h3 class="mb-2 flex items-center gap-2 text-base font-medium text-foreground transition-colors group-hover:text-foreground/80 sm:text-lg">
					Ethics
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 transition-all group-hover:translate-x-0.5 group-hover:opacity-70"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</h3>
				<p class="text-sm text-foreground/70 sm:text-base">
					Nonprofit initiative for engineers and technology decision-makers.
				</p>
			</a>
			
			<a href="/apps" class="group block">
				<h3 class="mb-2 flex items-center gap-2 text-base font-medium text-foreground transition-colors group-hover:text-foreground/80 sm:text-lg">
					Apps
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 transition-all group-hover:translate-x-0.5 group-hover:opacity-70"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
				</h3>
				<p class="text-sm text-foreground/70 sm:text-base">
					Applied software projects developed outside of client or advisory work.
				</p>
			</a>
		</div>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Selected focus areas
		</p>
		<ul class="space-y-3 text-sm text-foreground/70 sm:text-base">
			<li>Large-scale software systems</li>
			<li>Organizational design under constraint</li>
			<li>Technology governance and ethics</li>
			<li>Long-term system durability</li>
		</ul>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Recent writing
		</p>
		<div class="space-y-4">
			<a href="/insights" class="group block">
				<h3 class="mb-1 text-sm font-medium text-foreground transition-colors group-hover:text-foreground/80 sm:text-base">
					Coming soon
				</h3>
				<p class="text-sm text-foreground/50">
					Essays and analysis on technology governance.
				</p>
			</a>
		</div>
	</Section>

	<Section divider>
		<p class="mb-6 site-eyebrow">
			Current focus
		</p>
		<p class="text-sm leading-relaxed text-foreground/70 sm:text-base">
			Current focus includes work on long-lived software systems, organizational durability, and ethical constraints in technology decision-making.
		</p>
	</Section>

	<Section>
		<p class="mb-6 site-eyebrow">
			Correspondence
		</p>
		<p class="mb-3 text-sm leading-relaxed text-foreground/70 sm:text-base">
			Baldwinson operates as a principal-led practice.
			Inquiries related to the work, initiatives, or ethical frameworks documented here may be directed to:
		</p>
		<p class="mb-3 text-sm text-foreground sm:text-base">
			<ObfuscatedEmail user="curtis" domain="baldwinson.com" />
		</p>
		<p class="text-sm leading-relaxed text-foreground/70 sm:text-base">
			Not all inquiries require response. Those aligned with the scope and purpose of this work will be read with care.
		</p>
	</Section>
</Layout>
