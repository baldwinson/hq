---
import '../styles/global.css';
import { Navigation } from '@/components/Navigation';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Baldwinson", 
	description = "Baldwinson is not a company. It is a standard." 
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-background font-sans antialiased">
		<Navigation client:load currentPath={currentPath} />
		<main class="pt-16">
			<slot />
		</main>
		<footer class="border-t border-border/20 site-padding py-12">
			<div class="site-container">
				<p class="text-xs text-muted-foreground/50">
					© {new Date().getFullYear()} Baldwinson
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	/* ============================================
	   TYPOGRAPHY STACK
	   
	   Primary: Inter (everything)
	   Hero: Inter Display (weight 300, +tracking)
	   Subheads: Inter 400-500
	   Body: Inter 400, line-height 1.5-1.6
	   Nav: Inter 400, +0.02em tracking
	   ============================================ */
	
	.hero-section {
		font-family: 'Inter', system-ui, sans-serif;
	}
	
	.hero-primary {
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 300;
		letter-spacing: 0.01em;
		font-optical-sizing: auto;
	}
	
	.hero-secondary {
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 400;
		letter-spacing: 0.01em;
	}
	
	/* ============================================ */
	
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}
	
	body {
		margin: 0;
		min-height: 100vh;
	}
</style>
