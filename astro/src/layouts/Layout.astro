---
import '../styles/global.css';
import Navigation from '@/components/Navigation.astro';
import SEO from '@/components/SEO.astro';
import Favicons from '@/components/Favicons.astro';
import ThemeScript from '@/components/ThemeScript.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title?: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	publishedTime?: string;
	modifiedTime?: string;
	author?: string;
	noindex?: boolean;
}

const { 
	title = "Baldwinson", 
	description = "Building durable systems at the intersection of technology, ethics, and governance.",
	canonicalUrl,
	ogImage,
	ogType = 'website',
	publishedTime,
	modifiedTime,
	author,
	noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<ThemeScript />
		<Favicons />
		<meta name="generator" content={Astro.generator} />
		
		<SEO 
			title={title}
			description={description}
			canonicalUrl={canonicalUrl}
			ogImage={ogImage}
			ogType={ogType}
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
			author={author}
			noindex={noindex}
		/>
		
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Gelasio:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet" />
		
		<Analytics />
	</head>
	<body class="min-h-screen bg-background font-sans antialiased">
		<Navigation currentPath={currentPath} />
		<main class="pt-16">
			<slot />
		</main>
		<footer class="border-t border-border/20 site-padding py-12">
			<div class="site-container flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<p class="text-xs text-label">
					© {new Date().getFullYear()} Baldwinson
				</p>
				<nav class="flex gap-4" aria-label="Footer navigation">
					<a href="/privacy" class="text-xs text-label transition-colors hover:text-foreground">
						Privacy
					</a>
				</nav>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	/* ============================================
	   TYPOGRAPHY STACK
	   
	   Headings: Gelasio (serif)
	   Body/UI: Inter (sans-serif)
	   ============================================ */
	
	.hero-section {
		font-family: 'Inter', system-ui, sans-serif;
	}
	
	.hero-primary {
		font-family: 'Gelasio', Georgia, serif;
		font-weight: 400;
		letter-spacing: 0;
		font-optical-sizing: auto;
	}
	
	.hero-secondary {
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 400;
		letter-spacing: 0.01em;
	}
	
	/* ============================================ */
	
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}
	
	h1, h2 {
		font-family: 'Gelasio', Georgia, serif;
	}
	
	body {
		margin: 0;
		min-height: 100vh;
	}
</style>
